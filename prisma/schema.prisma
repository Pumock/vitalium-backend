generator client {
  provider = "prisma-client-js"
  output   = "../src/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////
// ENUMS
//////////////////////////////////////
enum UserRole {
  PATIENT
  CAREGIVER
  DOCTOR
  NURSE
  ADMIN
}

enum AdminRole {
  SUPER_ADMIN
  HOSPITAL_ADMIN
  CLINIC_ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BloodType {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum CaregiverRelationship {
  PARENT
  SPOUSE
  CHILD
  SIBLING
  GUARDIAN
  FRIEND
  OTHER
}

enum RecordType {
  CONSULTATION
  EXAMINATION
  SURGERY
  EMERGENCY
  ROUTINE_CHECKUP
  FOLLOW_UP
  DIAGNOSTIC
  OTHER
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum AppointmentType {
  CONSULTATION
  FOLLOW_UP
  ROUTINE_CHECKUP
  EMERGENCY
  SURGERY
  EXAMINATION
  VACCINATION
  OTHER
}

enum WardType {
  GENERAL
  ICU
  PEDIATRIC
  MATERNITY
  SURGERY
  EMERGENCY
  CARDIOLOGY
  ONCOLOGY
  OTHER
}

enum AdmissionStatus {
  ACTIVE
  DISCHARGED
  TRANSFERRED
}

enum LogLevel {
  ERROR
  WARN
  INFO
  DEBUG
  VERBOSE
}

enum SecurityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UnitType {
  HOSPITAL
  CLINIC
  CONSULTING_ROOM
  LAB
  OTHER
}

//////////////////////////////////////
// CORE MODELS
//////////////////////////////////////

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  avatar    String?
  isActive  Boolean  @default(true)
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient   Patient?
  caregiver Caregiver?
  doctor    Doctor?
  nurse     Nurse?
  admin     Admin?

  applicationLogs   ApplicationLog[]
  requestLogs       RequestLog[]
  securityLogs      SecurityLog[]
  databaseLogs      DatabaseLog[]
  businessEventLogs BusinessEventLog[]
  errorLogs         ErrorLog[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Unit {
  id        String   @id @default(cuid())
  name      String
  type      UnitType
  cnpj      String?  @unique
  phone     String?
  email     String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors       DoctorUnit[]
  nurses        NurseUnit[]
  patients      PatientUnit[]
  appointments  Appointment[]
  prescriptions Prescription[]
  wards         Ward[]

  @@map("units")
}

//////////////////////////////////////
// DOCTOR
//////////////////////////////////////

model Doctor {
  id        String   @id @default(cuid())
  userId    String   @unique
  crm       String   @unique
  crmState  Boolean
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  units           DoctorUnit[]
  specializations DoctorSpecialization[]
  medicalRecords  MedicalRecord[]
  appointments    Appointment[]
  prescriptions   Prescription[]
  patientDoctors  PatientDoctor[]

  @@index([crm])
  @@map("doctors")
}

model DoctorUnit {
  id                String   @id @default(cuid())
  doctorId          String
  unitId            String
  consultationPrice Decimal?
  isPrimary         Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([doctorId, unitId])
  @@index([doctorId])
  @@index([unitId])
  @@map("doctor_units")
}

model Specialization {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  doctors DoctorSpecialization[]

  @@map("specializations")
}

model DoctorSpecialization {
  id               String   @id @default(cuid())
  doctorId         String
  specializationId String
  createdAt        DateTime @default(now())

  doctor         Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialization Specialization @relation(fields: [specializationId], references: [id], onDelete: Cascade)

  @@unique([doctorId, specializationId])
  @@map("doctor_specializations")
}

//////////////////////////////////////
// NURSE
//////////////////////////////////////

model Nurse {
  id         String   @id @default(cuid())
  userId     String   @unique
  coren      String   @unique
  corenState Boolean
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  units NurseUnit[]

  @@index([coren])
  @@map("nurses")
}

model NurseUnit {
  id        String   @id @default(cuid())
  nurseId   String
  unitId    String
  wardId    String?
  isPrimary Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  nurse Nurse @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  unit  Unit  @relation(fields: [unitId], references: [id], onDelete: Cascade)
  ward  Ward? @relation(fields: [wardId], references: [id])

  @@unique([nurseId, unitId])
  @@index([nurseId])
  @@index([unitId])
  @@map("nurse_units")
}

//////////////////////////////////////
// ADMIN
//////////////////////////////////////

model Admin {
  id          String    @id @default(cuid())
  userId      String    @unique
  role        AdminRole
  permissions Json?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

//////////////////////////////////////
// PATIENT
//////////////////////////////////////

model Patient {
  id               String     @id @default(cuid())
  userId           String     @unique
  cpf              String     @unique
  rg               String?
  birthDate        DateTime
  gender           Gender
  bloodType        BloodType?
  allergies        String?
  emergencyContact String?
  emergencyPhone   String?
  address          String?
  city             String?
  state            String?
  zipCode          String?
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  units          PatientUnit[]
  caregivers     PatientCaregiver[]
  patientDoctors PatientDoctor[]

  // eventos
  medicalRecords MedicalRecord[]
  appointments   Appointment[]
  prescriptions  Prescription[]
  wardAdmissions WardAdmission[]

  @@index([cpf])
  @@map("patients")
}

model PatientUnit {
  id        String @id @default(cuid())
  patientId String
  unitId    String

  isPrimary Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  unit    Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([patientId, unitId])
  @@index([patientId])
  @@index([unitId])
  @@map("patient_units")
}

model Caregiver {
  id           String                @id @default(cuid())
  userId       String                @unique
  cpf          String                @unique
  relationship CaregiverRelationship
  isActive     Boolean               @default(true)
  createdAt    DateTime              @default(now())

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  patients PatientCaregiver[]

  @@map("caregivers")
}

model PatientCaregiver {
  id          String   @id @default(cuid())
  patientId   String
  caregiverId String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  caregiver Caregiver @relation(fields: [caregiverId], references: [id], onDelete: Cascade)

  @@unique([patientId, caregiverId])
  @@map("patient_caregivers")
}

model PatientDoctor {
  id        String    @id @default(cuid())
  patientId String
  doctorId  String
  startDate DateTime  @default(now())
  endDate   DateTime?
  createdAt DateTime  @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([patientId, doctorId])
  @@map("patient_doctors")
}

//////////////////////////////////////
// MEDICAL RECORDS
//////////////////////////////////////

model MedicalRecord {
  id           String     @id @default(cuid())
  patientId    String
  doctorId     String
  title        String
  description  String
  diagnosis    String?
  symptoms     String[]
  treatment    String?
  observations String?
  recordDate   DateTime   @default(now())
  recordType   RecordType
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  patient     Patient             @relation(fields: [patientId], references: [id])
  doctor      Doctor              @relation(fields: [doctorId], references: [id])
  attachments MedicalAttachment[]

  @@index([patientId])
  @@index([doctorId])
  @@map("medical_records")
}

model MedicalAttachment {
  id              String   @id @default(cuid())
  medicalRecordId String
  fileName        String
  fileUrl         String
  fileType        String
  fileSize        Int
  uploadedAt      DateTime @default(now())

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@map("medical_attachments")
}

//////////////////////////////////////
// APPOINTMENTS
//////////////////////////////////////

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  doctorId    String
  unitId      String
  title       String
  description String?
  scheduledAt DateTime
  duration    Int               @default(30)
  status      AppointmentStatus @default(SCHEDULED)
  type        AppointmentType
  price       Decimal?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])
  unit    Unit    @relation(fields: [unitId], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@map("appointments")
}

//////////////////////////////////////
// PRESCRIPTIONS
//////////////////////////////////////

model Prescription {
  id           String   @id @default(cuid())
  patientId    String
  doctorId     String
  unitId       String
  medication   String
  dosage       String
  frequency    String
  duration     String
  instructions String?
  prescribedAt DateTime @default(now())
  createdAt    DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])
  unit    Unit    @relation(fields: [unitId], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@map("prescriptions")
}

//////////////////////////////////////
// WARDS
//////////////////////////////////////

model Ward {
  id          String   @id @default(cuid())
  unitId      String
  name        String
  type        WardType
  capacity    Int
  currentLoad Int      @default(0)
  floor       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  unit       Unit            @relation(fields: [unitId], references: [id])
  nurses     NurseUnit[]
  admissions WardAdmission[]

  @@index([unitId])
  @@map("wards")
}

model WardAdmission {
  id            String          @id @default(cuid())
  patientId     String
  wardId        String
  admissionDate DateTime        @default(now())
  dischargeDate DateTime?
  reason        String
  status        AdmissionStatus @default(ACTIVE)
  notes         String?
  createdAt     DateTime        @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
  ward    Ward    @relation(fields: [wardId], references: [id])

  @@index([patientId])
  @@index([wardId])
  @@map("ward_admissions")
}

// ================================
// MONITORING & LOGGING TABLES
// ================================

// Application Logs
model ApplicationLog {
  id          String   @id @default(cuid())
  level       LogLevel
  message     String
  context     String?
  trace       String?
  meta        Json?
  timestamp   DateTime @default(now())
  service     String   @default("vitalium-backend")
  environment String   @default("development")
  userId      String?
  sessionId   String?
  requestId   String?

  // Foreign keys
  user User? @relation(fields: [userId], references: [id])

  @@index([level])
  @@index([timestamp])
  @@index([userId])
  @@index([context])
  @@map("application_logs")
}

// HTTP Request Logs
model RequestLog {
  id           String   @id @default(cuid())
  method       String
  url          String
  statusCode   Int
  duration     Int // in milliseconds
  ip           String?
  userAgent    String?
  userId       String?
  requestId    String   @unique
  requestBody  Json?
  responseBody Json?
  headers      Json?
  timestamp    DateTime @default(now())

  // Foreign keys
  user User? @relation(fields: [userId], references: [id])

  @@index([method])
  @@index([statusCode])
  @@index([timestamp])
  @@index([userId])
  @@index([duration])
  @@map("request_logs")
}

// Security Audit Logs
model SecurityLog {
  id          String        @id @default(cuid())
  event       String
  severity    SecurityLevel
  description String?
  userId      String?
  ip          String?
  userAgent   String?
  metadata    Json?
  timestamp   DateTime      @default(now())

  // Foreign keys
  user User? @relation(fields: [userId], references: [id])

  @@index([event])
  @@index([severity])
  @@index([timestamp])
  @@index([userId])
  @@map("security_logs")
}

// Database Operation Logs
model DatabaseLog {
  id        String   @id @default(cuid())
  operation String // SELECT, INSERT, UPDATE, DELETE
  table     String
  duration  Float // in milliseconds
  queryType String? // CRUD operation type
  userId    String?
  metadata  Json?
  timestamp DateTime @default(now())

  // Foreign keys
  user User? @relation(fields: [userId], references: [id])

  @@index([operation])
  @@index([table])
  @@index([timestamp])
  @@index([userId])
  @@index([duration])
  @@map("database_logs")
}

// Business Event Logs
model BusinessEventLog {
  id        String   @id @default(cuid())
  event     String
  entity    String
  entityId  String
  userId    String?
  metadata  Json?
  timestamp DateTime @default(now())

  // Foreign keys
  user User? @relation(fields: [userId], references: [id])

  @@index([event])
  @@index([entity])
  @@index([entityId])
  @@index([timestamp])
  @@index([userId])
  @@map("business_event_logs")
}

// API Usage Statistics
model ApiUsageStatistic {
  id          String   @id @default(cuid())
  endpoint    String
  method      String
  count       Int      @default(1)
  avgDuration Float?
  minDuration Float?
  maxDuration Float?
  errorCount  Int      @default(0)
  date        DateTime @db.Date
  hour        Int? // 0-23 for hourly stats

  @@unique([endpoint, method, date, hour])
  @@index([endpoint])
  @@index([date])
  @@map("api_usage_statistics")
}

// Error Tracking
model ErrorLog {
  id           String    @id @default(cuid())
  errorType    String
  errorMessage String
  stackTrace   String?
  userId       String?
  requestId    String?
  context      String?
  metadata     Json?
  timestamp    DateTime  @default(now())
  resolved     Boolean   @default(false)
  resolvedAt   DateTime?
  resolvedBy   String?

  // Foreign keys
  user User? @relation(fields: [userId], references: [id])

  @@index([errorType])
  @@index([timestamp])
  @@index([userId])
  @@index([resolved])
  @@map("error_logs")
}
