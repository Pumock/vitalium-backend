{
    "$schema": "https://biomejs.dev/schemas/2.4.2/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "includes": [
            "src/**",
            "test/**",
            "!src/prisma/generated/**",
            "!dist/**",
            "!node_modules/**",
            "!coverage/**"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 2,
        "lineWidth": 80
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "correctness": {
                "noUnusedFunctionParameters": "off"
            },
            "suspicious": {
                "noExplicitAny": "off"
            },
            "complexity": {
                "noStaticOnlyClass": "off",
                "noUselessConstructor": "off"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "trailingCommas": "all",
            "semicolons": "always"
        },
        "parser": {
            "unsafeParameterDecoratorsEnabled": true
        }
    }
}