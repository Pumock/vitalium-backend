{
  "name": "vitalium-backend",
  "version": "0.0.1",
  "description": "API for vitalium",
  "author": "",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "biome lint --write ./src ./test",
    "format": "biome format --write ./src ./test",
    "format:check": "biome format ./src ./test",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "dev": "docker compose -f docker-compose.dev.yml --env-file .env.development up",
    "dev:build": "docker compose -f docker-compose.dev.yml --env-file .env.development up --build",
    "dev:stop": "docker compose -f docker-compose.dev.yml down",
    "dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "dev:clean": "docker compose -f docker-compose.dev.yml down -v --remove-orphans",
    "prod": "docker compose --env-file .env.production up -d",
    "prod:build": "docker compose --env-file .env.production up --build -d",
    "prod:stop": "docker compose down",
    "infra": "docker compose -f docker-compose.dev.yml --env-file .env.development up postgres -d",
    "infra:stop": "docker compose -f docker-compose.dev.yml --env-file .env.development stop postgres",
    "migrate": "npx prisma migrate dev",
    "migrate:prod": "npx prisma migrate deploy",
    "staging": "docker compose --env-file .env.staging up -d"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "pg": "^8.16.3",
    "prisma": "^7.2.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "jest": "^29.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "overrides": {
    "js-yaml": "^4.1.0",
    "hono": "^4.10.3",
    "valibot": "^1.2.0",
    "diff": "^8.0.3",
    "fast-xml-parser": "^5.4.0",
    "lodash": "^4.17.21",
    "schema-utils": "^4.2.0",
    "minimatch": "^10.2.1",
    "ajv": "^8.18.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    }
  }
}